                        <label style={{ fontSize: 12, fontWeight: 600, display: "block", marginBottom: 4 }}>Vent de face (m/s)</label>
                        <div style={{ display: "flex", alignItems: "center", gap: 6 }}>
                          <input type="range" min="-5" max="5" step="0.5" value={meteoVentFace}
                            onChange={(e) => setMeteoVentFace(parseFloat(e.target.value))} style={{ width: 120 }} />
                          <span style={{ fontFamily: "monospace", fontSize: 13, width: 54 }}>
                            {meteoVentFace > 0 ? "+" : ""}{meteoVentFace} m/s
                          </span>
                        </div>
                        <div style={{ fontSize: 11, color: "var(--text-tertiary)", marginTop: 2 }}>Négatif = vent dans le dos</div>
                      </div>
                      <div>
                        <label style={{ fontSize: 12, fontWeight: 600, display: "block", marginBottom: 4 }}>Température de l'eau (°C)</label>
                        <div style={{ display: "flex", alignItems: "center", gap: 6 }}>
                          <input type="range" min="4" max="30" step="1" value={meteoTempEau}
                            onChange={(e) => setMeteoTempEau(parseFloat(e.target.value))} style={{ width: 120 }} />
                          <span style={{ fontFamily: "monospace", fontSize: 13, width: 40 }}>{meteoTempEau}°C</span>
                        </div>
                        <div style={{ fontSize: 11, color: "var(--text-tertiary)", marginTop: 2 }}>Référence : 26°C</div>
                      </div>
                    </div>
                  )}

                  {/* Boutons communs */}
                  <div style={{ display: "flex", gap: 8, alignItems: "center", flexWrap: "wrap" }}>
                    <button className={meteoEnabled ? "primary" : ""}
                      disabled={meteoMode === "auto" && !meteoAutoResult}
                      onClick={() => setMeteoEnabled((v) => !v)}>
                      {meteoEnabled ? "✓ Correction active — désactiver" : "Appliquer la correction"}
                    </button>
                    <button onClick={() => { setMeteoVentFace(0); setMeteoTempEau(20); setMeteoEnabled(false); setMeteoAutoResult(null); setMeteoError(null); }}>
                      Réinitialiser
                    </button>
                    <span style={{ fontSize: 11, color: "var(--text-tertiary)", marginLeft: 4 }}>
                      Ramène les chronos vers conditions de référence (vent 0, eau 26°C) · colonne <b>Temps corrigé</b>
                    </span>
                  </div>
                </div>
              </div>
            )}
          </div>

          <div style={{ display: "flex", gap: 16, marginBottom: 10, fontSize: 12, color: "var(--text-secondary)" }}>
            <span style={{ display: "flex", alignItems: "center", gap: 5 }}>
              <span style={{ width: 10, height: 10, borderRadius: 2, background: "#5DCAA5", display: "inline-block" }} />écart &lt; 2 %
            </span>
            <span style={{ display: "flex", alignItems: "center", gap: 5 }}>
              <span style={{ width: 10, height: 10, borderRadius: 2, background: "#FAC775", display: "inline-block" }} />2–4 %
            </span>
            <span style={{ display: "flex", alignItems: "center", gap: 5 }}>
              <span style={{ width: 10, height: 10, borderRadius: 2, background: "#F0997B", display: "inline-block" }} />&gt; 4 %
            </span>
            <span style={{ marginLeft: "auto" }}>{filteredRows.length} ligne{filteredRows.length > 1 ? "s" : ""}</span>
          </div>

          <div style={{ overflowX: "auto", border: "1px solid var(--border-strong)", borderRadius: 10, background: "var(--bg-primary)" }}>
            <table>
              <thead>
                <tr>
                  {[colRegate, colEpreuve, colPos, showIdentity ? colEquipage : null, colClubVisible, colBarreurVisible, colBateau, colCat, colTemps, colRefVisible, colPct, colGap]
                    .filter(Boolean)
                    .map((c) => (
                      <th key={c} onClick={() => toggleSort(c)}>
                        {c}{sortKey === c ? (sortDir === "asc" ? " ▲" : " ▼") : ""}
                      </th>
                    ))}
                  {colPct && showRelPct && Object.keys(bestPctByRace).length > 0 && (
                    <th onClick={() => toggleSort("__relPct")}>
                      % Relatif (course){sortKey === "__relPct" ? (sortDir === "asc" ? " ▲" : " ▼") : ""}
                    </th>
                  )}
                  {meteoEnabled && colTemps && <th title="Chrono ramené aux conditions de référence (vent 0 m/s, eau 26°C) — Kleshnev/Filter">Temps corrigé ⚙</th>}
                </tr>
              </thead>
              <tbody>
                {filteredRows.slice(0, 500).map((r, i) => {
                  const pct = colGap ? pctNum(r[colGap]) : null;
                  const rp = relPct(r);
                  const rpGap = rp !== null ? 100 - rp : null;
                  return (
                    <tr key={i}>
                      {colRegate && (
                        <td style={{ whiteSpace: "nowrap" }}>
                          <span
                            className="pill"
                            title={r[colRegate]}
                            style={{
                              background: (regateMeta[r[colRegate]]?.color || "#888780") + "1f",
                              color: regateMeta[r[colRegate]]?.color || "#5f5e5a",
                              fontWeight: 600,
                            }}
                          >
                            {regateMeta[r[colRegate]]?.short || r[colRegate]}
                          </span>
                        </td>
                      )}
                      {colEpreuve && (
                        <td style={{ whiteSpace: "nowrap" }}>
                          <div style={{ fontWeight: 600 }}>{r[colEpreuve]}</div>
                          {colType && <div style={{ fontSize: 11, color: "var(--text-tertiary)" }}>{r[colType]}</div>}
                        </td>
                      )}
                      {colPos && <td style={{ fontWeight: 600, textAlign: "center" }}>{r[colPos]}</td>}
                      {colEquipage && showIdentity && <td>{r[colEquipage]}</td>}
                      {colClubVisible && <td style={{ color: "var(--text-secondary)", fontSize: 12 }}>{r[colClubVisible]}</td>}
                      {colBarreurVisible && <td style={{ color: "var(--text-secondary)", fontSize: 12 }}>{r[colBarreurVisible]}</td>}
                      {colBateau && <td style={{ textAlign: "center" }}>{r[colBateau]}</td>}
                      {colCat && <td style={{ color: "var(--text-secondary)", whiteSpace: "nowrap" }}>{r[colCat]}</td>}
                      {colTemps && (
                        <td style={{ fontFamily: "monospace" }}>
                          <div>{r[colTemps]}</div>
                          {showSplit500 && (
                            <div style={{ fontStyle: "italic", fontSize: 10.5, color: "var(--text-tertiary)" }}>
                              {split500(r[colTemps], colDistance ? r[colDistance] : null) || "—"}
                            </div>
                          )}
                        </td>
                      )}
                      {colRefVisible && <td style={{ fontFamily: "monospace", color: "var(--text-secondary)" }}>{r[colRefVisible]}</td>}
                      {colPct && <td style={{ fontFamily: "monospace", fontWeight: 600 }}>{r[colPct]}</td>}
                      {colGap && (
                        <td>
                          <span className="pill" style={{ background: fieldBg(pct), color: fieldColor(pct) }}>{r[colGap]}</span>
                        </td>
                      )}
                      {colPct && showRelPct && Object.keys(bestPctByRace).length > 0 && (
                        <td style={{ fontFamily: "monospace" }}>
                          {rp !== null ? (
                            <span className="pill" style={{ background: fieldBg(rpGap), color: fieldColor(rpGap) }}>
                              {rp.toFixed(2)}%
                            </span>
                          ) : "—"}
                        </td>
                      )}
                      {meteoEnabled && colTemps && (() => {
                        const boat = colBateau ? r[colBateau] : null;
                        // 1. Correction vent + température
                        let corrSec = applyMeteoCorrection(r[colTemps], boat, meteoVentFace, meteoTempEau);
                        // 2. Correction courant (rivière seulement, si résultat auto disponible)
                        const courantMs = meteoAutoResult && meteoAutoResult.typeEau === "riviere_courant"
                          ? meteoAutoResult.courantMs * courantSens : 0;
                        if (corrSec !== null && courantMs) {
                          const distStr = colDistance ? r[colDistance] : null;
                          const distMatch = distStr ? String(distStr).match(/(\d+)/) : null;
                          const distM = distMatch ? parseInt(distMatch[1], 10) : 2000;
                          corrSec = correctionCourant(corrSec, distM, courantMs);
                        }
                        const raw = parseTimeStr(r[colTemps]);
                        const diffSec = corrSec !== null && raw !== null ? corrSec - raw : null;
                        const distStr = colDistance ? r[colDistance] : null;
                        const distMatch = distStr ? String(distStr).match(/(\d+)/) : null;
                        const dist = distMatch ? parseInt(distMatch[1], 10) : 2000;
                        const segments = dist / 500;
                        const corrSplit = corrSec !== null && segments ? fmtTimeStr(corrSec / segments) : null;
                        return (
                          <td style={{ fontFamily: "monospace" }}>
                            {corrSec !== null ? (
                              <div>
                                <span style={{ fontWeight: 600 }}>{fmtTimeStr(corrSec)}</span>
                                {showSplit500 && corrSplit && (
                                  <div style={{ fontStyle: "italic", fontSize: 10.5, color: "var(--text-tertiary)" }}>
                                    {corrSplit} /500m
                                  </div>
                                )}
                                {diffSec !== null && (
                                  <div style={{ fontSize: 10.5, color: diffSec > 0 ? "#854F0B" : "#0F6E56" }}>
                                    {diffSec > 0 ? "+" : ""}{diffSec.toFixed(1)}s vs brut
                                  </div>
                                )}
                              </div>
                            ) : "—"}
                          </td>
                        );
                      })()}
                    </tr>
                  );
                })}
              </tbody>
            </table>
          </div>
          {filteredRows.length > 500 && (
            <p style={{ fontSize: 12, color: "var(--text-tertiary)", marginTop: 8 }}>
              Affichage limité aux 500 premières lignes ({filteredRows.length} au total) — affine les filtres pour réduire.
            </p>
          )}
          {error && <p style={{ color: "#993C1D", fontSize: 13, marginTop: 12 }}>{error}</p>}
          </React.Fragment>
          )}

          {viewMode === "athletes" && (
            <div>
              <p style={{ fontSize: 13, color: "var(--text-secondary)", marginBottom: 12 }}>
                Classement par athlète — moyenne du {rankMode === "ffa" ? "% FFA-DTN" : "% Relatif"} calculée sur {filteredRows.length} résultat{filteredRows.length > 1 ? "s" : ""} filtré{filteredRows.length > 1 ? "s" : ""}.
              </p>
              <div className="no-print" style={{ display: "flex", gap: 6, marginBottom: 10, flexWrap: "wrap" }}>
                <button className={sexFilter === "all" ? "primary" : ""} onClick={() => setSexFilter("all")}>Tous</button>
                <button className={sexFilter === "H" ? "primary" : ""} onClick={() => setSexFilter("H")}>Hommes</button>
                <button className={sexFilter === "F" ? "primary" : ""} onClick={() => setSexFilter("F")}>Femmes</button>
              </div>
              <div className="no-print" style={{ display: "flex", gap: 6, marginBottom: 12, alignItems: "center", flexWrap: "wrap" }}>
                <span style={{ fontSize: 12, color: "var(--text-tertiary)" }}>Classer par :</span>
                <button className={rankMode === "relatif" ? "primary" : ""} onClick={() => setRankMode("relatif")}>% Relatif</button>
                <button className={rankMode === "ffa" ? "primary" : ""} onClick={() => setRankMode("ffa")}>% FFA-DTN</button>
              </div>
              {(() => {
                const sexScopedList = sexFilter === "all" ? athleteSummary : athleteSummary.filter((a) => a.sex === sexFilter);
                const pickerMatches = athletePickerSearch.trim()
                  ? sexScopedList.filter((a) => a.name.toLowerCase().includes(athletePickerSearch.trim().toLowerCase()))
                  : sexScopedList;
                return (
                  <div className="no-print" style={{ marginBottom: 16, position: "relative" }}>
                    <div style={{ display: "flex", gap: 8, alignItems: "center", flexWrap: "wrap" }}>
                      <button onClick={() => setAthletePickerOpen((v) => !v)}>
                        {selectedAthletes.length === 0 ? "Sélectionner des athlètes" : `${selectedAthletes.length} athlète${selectedAthletes.length > 1 ? "s" : ""} sélectionné${selectedAthletes.length > 1 ? "s" : ""}`} {athletePickerOpen ? "▲" : "▼"}
                      </button>
                      {selectedAthletes.length > 0 && (
                        <button onClick={() => setSelectedAthletes([])}>Voir tous ({sexScopedList.length})</button>
                      )}
                    </div>
                    {athletePickerOpen && (
                      <div
                        style={{
                          position: "absolute", zIndex: 10, top: "calc(100% + 6px)", left: 0,
                          width: 320, maxHeight: 360, overflowY: "auto", background: "var(--bg-primary)",
                          border: "1px solid var(--border-strong)", borderRadius: 10, padding: 10,
                          boxShadow: "0 8px 24px rgba(0,0,0,0.12)",
                        }}
                      >
                        <input
                          type="text"
                          placeholder="Rechercher un athlète..."
                          value={athletePickerSearch}
                          onChange={(e) => setAthletePickerSearch(e.target.value)}
                          style={{ width: "100%", marginBottom: 8 }}
                          autoFocus
                        />
                        <div style={{ display: "flex", gap: 8, marginBottom: 8, fontSize: 12 }}>
                          <span
                            style={{ cursor: "pointer", color: "var(--accent)", textDecoration: "underline" }}
                            onClick={() => setSelectedAthletes(sexScopedList.map((a) => a.key))}
                          >
                            Tout cocher
                          </span>
                          <span
                            style={{ cursor: "pointer", color: "var(--accent)", textDecoration: "underline" }}
                            onClick={() => setSelectedAthletes([])}
                          >
                            Tout décocher
                          </span>
                        </div>
                        {pickerMatches.map((a) => (
                          <label key={a.key} style={{ display: "flex", alignItems: "center", gap: 8, padding: "4px 2px", fontSize: 13, cursor: "pointer" }}>
                            <input
                              type="checkbox"
                              checked={selectedAthletes.includes(a.key)}
                              onChange={(e) => {
                                setSelectedAthletes((prev) =>
                                  e.target.checked ? [...prev, a.key] : prev.filter((k) => k !== a.key)
                                );
                              }}
                            />
                            {a.name} <span style={{ color: "var(--text-tertiary)" }}>({a.sex})</span>
                          </label>
                        ))}
                        {pickerMatches.length === 0 && (
                          <div style={{ fontSize: 12, color: "var(--text-tertiary)", padding: 6 }}>Aucun athlète trouvé</div>
                        )}
                      </div>
                    )}
                  </div>
                );
              })()}

              {(() => {
                const list = (sexFilter === "all" ? athleteSummary : athleteSummary.filter((a) => a.sex === sexFilter))
                  .filter((a) => selectedAthletes.length === 0 || selectedAthletes.includes(a.key));
                return (
                  <div style={{ overflowX: "auto", border: "1px solid var(--border-strong)", borderRadius: 10, background: "var(--bg-primary)" }}>
                    <table>
                      <thead>
                        <tr>
                          <th rowSpan={2} style={{ width: 32 }}>#</th>
                          <th rowSpan={2} style={{ textAlign: "left" }}>Athlète</th>
                          {sexFilter === "all" && <th rowSpan={2} style={{ textAlign: "center" }}>Sexe</th>}
                          {raceList.map((race) => (
                            <th
                              key={race}
                              colSpan={3}
                              style={{
                                textAlign: "center",
                                background: (raceColorByShort[race] || "#888780") + "15",
                                color: raceColorByShort[race] || "var(--text-secondary)",
                                borderLeft: "1px solid var(--border-strong)",
                              }}
                            >
                              {race}
                            </th>
                          ))}
                          <th rowSpan={2} style={{ borderLeft: "1px solid var(--border-strong)" }}>{rankMode === "ffa" ? "% FFA-DTN moyen" : "% Relatif moyen"}</th>
                        </tr>
                        <tr>
                          {raceList.map((race) => (
                            <React.Fragment key={race}>
                              <th style={{ fontSize: 11, fontWeight: 500, color: "var(--text-tertiary)", borderLeft: "1px solid var(--border-strong)" }}>Bateau</th>
                              <th style={{ fontSize: 11, fontWeight: 500, color: "var(--text-tertiary)" }}>% FFA</th>
                              <th style={{ fontSize: 11, fontWeight: 500, color: "var(--text-tertiary)" }}>% Relatif</th>
                            </React.Fragment>
                          ))}
                        </tr>
                      </thead>
                      <tbody>
                        {list.map((a, idx) => (
                          <tr key={a.key}>
                            <td style={{ textAlign: "center", color: "var(--text-tertiary)" }}>{idx + 1}</td>
                            <td style={{ fontWeight: 600, whiteSpace: "nowrap" }}>{a.name}</td>
                            {sexFilter === "all" && (
                              <td style={{ textAlign: "center", color: "var(--text-secondary)" }}>{a.sex}</td>
                            )}
                            {raceList.map((race) => {
                              const perfs = a.byRace[race] || [];
                              if (perfs.length === 0) {
                                return (
                                  <React.Fragment key={race}>
                                    <td style={{ textAlign: "center", color: "var(--text-tertiary)", borderLeft: "1px solid var(--border)" }}>—</td>
                                    <td style={{ textAlign: "center", color: "var(--text-tertiary)" }}>—</td>
                                    <td style={{ textAlign: "center", color: "var(--text-tertiary)" }}>—</td>
                                  </React.Fragment>
                                );
                              }
                              return (
                                <React.Fragment key={race}>
                                  <td style={{ textAlign: "center", whiteSpace: "nowrap", borderLeft: "1px solid var(--border)" }}>
                                    {perfs.map((p) => p.bateau).join(", ")}
                                  </td>
                                  <td style={{ fontFamily: "monospace", textAlign: "center", whiteSpace: "nowrap" }}>
                                    {perfs.map((p) => (p.pct !== null ? `${p.pct.toFixed(2)}%` : "—")).join(", ")}
                                  </td>
                                  <td style={{ textAlign: "center", whiteSpace: "nowrap" }}>
                                    {perfs.map((p, i) => (
                                      p.relPct !== null ? (
                                        <span key={i} className="pill" style={{ background: fieldBg(100 - p.relPct), color: fieldColor(100 - p.relPct), marginRight: 4, fontFamily: "monospace" }}>
                                          {p.relPct.toFixed(2)}%
                                        </span>
                                      ) : "—"
                                    ))}
                                  </td>
                                </React.Fragment>
                              );
                            })}
                            <td style={{ fontFamily: "monospace", fontWeight: 700, borderLeft: "1px solid var(--border-strong)" }}>
                              {rankMode === "ffa" ? (
                                a.avgPct !== null ? <span>{a.avgPct.toFixed(2)}%</span> : "—"
                              ) : (
                                a.avgRelPct !== null ? (
                                  <span className="pill" style={{ background: fieldBg(100 - a.avgRelPct), color: fieldColor(100 - a.avgRelPct) }}>
                                    {a.avgRelPct.toFixed(2)}%
                                  </span>
                                ) : "—"
                              )}
                            </td>
                          </tr>
                        ))}
                        {list.length === 0 && (
                          <tr><td colSpan={4 + raceList.length * 3} style={{ textAlign: "center", color: "var(--text-tertiary)", padding: 16 }}>Aucun athlète</td></tr>
                        )}
                      </tbody>
                    </table>
                  </div>
                );
              })()}
            </div>
          )}

          {viewMode === "clubs" && colPts && (
            <div>
              <h3 style={{ margin: "0 0 16px", fontSize: 16, fontWeight: 600 }}>
                🏆 Classement par clubs
                <span style={{ fontSize: 12, fontWeight: 400, color: "var(--text-tertiary)", marginLeft: 12 }}>
                  {clubsClassement.length} clubs · points provisoires
                </span>
              </h3>
              <table>
                <thead>
                  <tr>
                    <th style={{ width: 50, textAlign: "center" }}>Place</th>
                    <th>Club</th>
                    <th style={{ width: 100, textAlign: "right" }}>Points</th>
                    <th>Détail</th>
                  </tr>
                </thead>
                <tbody>
                  {clubsClassement.map((c) => (
                    <tr key={c.club} style={{ background: c.rank <= 3 ? "var(--bg-secondary)" : undefined }}>
                      <td style={{ textAlign: "center", fontWeight: 700, fontSize: 15 }}>
                        {c.rank === 1 ? "🥇" : c.rank === 2 ? "🥈" : c.rank === 3 ? "🥉" : c.rank}
                      </td>
                      <td style={{ fontWeight: 600 }}>{c.club}</td>
                      <td style={{ textAlign: "right", fontWeight: 700, fontFamily: "monospace", fontSize: 15 }}>
                        {c.total % 1 === 0 ? c.total : c.total.toFixed(1)}
                      </td>
                      <td style={{ fontSize: 11, color: "var(--text-secondary)" }}>
                        {c.details.map((d, i) => (
                          <span key={i} style={{ marginRight: 8, whiteSpace: "nowrap" }}>
                            {d.epreuve} {d.place}e ({d.pts}pts)
                          </span>
                        ))}
                      </td>
                    </tr>
                  ))}
                  {clubsClassement.length === 0 && (
                    <tr><td colSpan={4} style={{ textAlign: "center", color: "var(--text-tertiary)", padding: 16 }}>Aucune donnée de points</td></tr>
                  )}
                </tbody>
              </table>
            </div>
          )}
        </div>
      )}
    </div>
  );
}

ReactDOM.createRoot(document.getElementById("root")).render(<App />);
</script>
</body>
</html>
