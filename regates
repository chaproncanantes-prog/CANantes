        if (isPdf) {
          const buf = await file.arrayBuffer();
          // On essaie d'abord notre propre format d'export "Classement" (positions de colonnes).
          const ownExport = await parsePdfClassement(buf.slice(0));
          if (ownExport.rows.length > 0) {
            if (ownExport.rows.every((r) => r["Régate"] === "Course PDF")) {
              const fallbackTitle = label.replace(/\.pdf$/i, "");
              ownExport.rows.forEach((r) => { r["Régate"] = fallbackTitle; });
            }
            ingestParsed(ownExport, label);
          } else {
            // Pas un export "Classement" reconnu → on vérifie si c'est un PDF World Rowing.
            const text = await extractPdfPlainText(buf.slice(0));
            if (looksLikeWorldRowingPdf(text)) {
              const wrParsed = await parseWorldRowingPdf(buf.slice(0), label.replace(/\.pdf$/i, ""));
              if (wrParsed.rows.length > 0) {
                ingestParsed(wrParsed, label);
              } else {
                setError(`Aucun résultat World Rowing exploitable trouvé dans "${label}".`);
              }
            } else {
              // Fallback : moteur CrewTimer brut.
              queueRawItem({ kind: "pdf-raw", text, fileLabel: label.replace(/\.pdf$/i, "") });
            }
          }
        } else {
          const text = await file.text();
          if (isAlreadyProcessed(text)) {
            loadCSV(text, label);
          } else {
            queueRawItem({ kind: "csv-raw", text, fileLabel: label.replace(/\.csv$/i, "") });
          }
        }
      } catch (e) {
        setError(`Erreur de lecture de "${label}" : ${e.message}`);
      }
    }
  };

  const onDrop = (e) => {
    e.preventDefault();
    setDragOver(false);
    if (e.dataTransfer.files?.length) handleFile(e.dataTransfer.files);
  };

  const handlePaste = (e) => {
    const text = e.clipboardData.getData("text");
    if (!text) return;
    if (text.includes(",") && isAlreadyProcessed(text)) {
      e.preventDefault();
      loadCSV(text, "Collé");
    } else if (looksLikeRawCrewTimerText(text)) {
      e.preventDefault();
      queueRawItem({ kind: "csv-raw", text, fileLabel: "Collé" });
    } else if (text.includes(",")) {
      e.preventDefault();
      loadCSV(text, "Collé");
    }
  };

  const cols = data?.headers || [];
  const find = (name) => cols.find((c) => c.toLowerCase().includes(name.toLowerCase())) || null;

  const colRegate = find("régate") || find("regate");
  const colJournee = find("journée") || find("journee");
  const colEpreuve = find("épreuve") || find("epreuve");
  const colType = find("type");
  const colPos = find("pos");
  const colEquipage = find("équipage") || find("equipage");
  const colBarreur = find("nage") || find("barreur");
  const colClub = find("club") || find("Club") || null;
  const colBateau = find("bateau");
  const colCat = find("catégorie") || find("categorie");
  const colTemps = find("temps");
  const colDistance = find("distance");
  const colRef = find("référence") || find("reference");
  const colPct = find("ffa") || find("niveau dtn") || find("% ");
  const colPts = find("points");
  const colGap = find("écart") || find("ecart");

  // Masque les colonnes détectées mais vides sur toutes les lignes (ex. Nage/Barreur,
  // Référence DTN ne sont jamais renseignées par l'import PDF) pour gagner de la place.
  const colHasData = (col) => !!data && !!col && data.rows.some((r) => String(r[col] || "").trim() !== "");
  const colBarreurVisible = colHasData(colBarreur) ? colBarreur : null;
  const colRefVisible = colHasData(colRef) ? colRef : null;
  const colClubVisible = colHasData(colClub) ? colClub : null;

  // Les noms de course se ressemblent souvent ("RS2 U19 vendredi matin", "RS2 U19
  // vendredi midi"...) — on retire la partie commune pour n'afficher que ce qui les
  // distingue, et on attribue une couleur par course pour les repérer d'un coup d'œil.
  const RACE_COLORS = ["#0c447c", "#0F6E56", "#854F0B", "#993C1D", "#5b3a8e", "#1d6f93", "#a6463a", "#3f6b1f"];
  const regateMeta = useMemo(() => {
    if (!data || !colRegate) return {};
    const values = [...new Set(data.rows.map((r) => r[colRegate]).filter(Boolean))];
    let prefix = values[0] || "";
    values.slice(1).forEach((v) => {
      let i = 0;
      while (i < prefix.length && i < v.length && prefix[i] === v[i]) i++;
      prefix = prefix.slice(0, i);
    });
    const trimmedPrefix = values.length > 1 ? prefix.replace(/\S*$/, "") : "";
    const map = {};
    values.forEach((v, i) => {
      let short = v.slice(trimmedPrefix.length).trim().replace(/^[—\-:,]+\s*/, "");
      map[v] = { short: short || v, color: RACE_COLORS[i % RACE_COLORS.length] };
    });
    return map;
  }, [data, colRegate]);


  // Meilleur % FFA-DTN PAR COURSE (groupé par colonne Régate, ou par fichier source
  // si la colonne Régate est absente) — chaque course a sa propre référence à 100%,
  // ce qui permet de comparer où se situe chaque équipage au sein de SA course,
  // tout en gardant le % FFA-DTN brut comparable entre les différentes courses.
  const bestPctByRace = useMemo(() => {
    if (!data || !colPct) return {};
    const map = {};
    data.rows.forEach((r) => {
      const key = colRegate ? (r[colRegate] || "?") : (r.__srcFile || "?");
      const p = pctNum(r[colPct]);
      if (p === null) return;
      if (!(key in map) || p > map[key]) map[key] = p;
    });
    return map;
  }, [data, colPct, colRegate]);

  const relPct = (r) => {
    if (!colPct) return null;
    const key = colRegate ? (r[colRegate] || "?") : (r.__srcFile || "?");
    const best = bestPctByRace[key];
    if (!best) return null;
    const p = pctNum(r[colPct]);
    if (p === null) return null;
    return (p / best) * 100;
  };

  const filterOptions = (col) => {
    if (!data || !col) return [];
    return [...new Set(data.rows.map((r) => r[col]).filter(Boolean))].sort();
  };

  const regateOptions = useMemo(() => filterOptions(colRegate), [data, colRegate]);
  const journeeOptions = useMemo(() => filterOptions(colJournee), [data, colJournee]);
  const epreuveOptions = useMemo(() => filterOptions(colEpreuve), [data, colEpreuve]);

  const filteredRows = useMemo(() => {
    if (!data) return [];
    let rows = data.rows;
    if (selectedRegates.length && colRegate) rows = rows.filter((r) => selectedRegates.includes(r[colRegate]));
    if (selectedJournees.length && colJournee) rows = rows.filter((r) => selectedJournees.includes(r[colJournee]));
    if (selectedEpreuves.length && colEpreuve) rows = rows.filter((r) => selectedEpreuves.includes(r[colEpreuve]));
    if (selectedTypes.length && colType) rows = rows.filter((r) => selectedTypes.includes(r[colType]));
    if (!sortKey && colType) rows = [...rows].sort((a,b) => { const d = typeRank(a[colType]) - typeRank(b[colType]); return d !== 0 ? d : parseInt(a[colPos]||99) - parseInt(b[colPos]||99); });
    if (search.trim()) {
      const s = search.trim().toLowerCase();
      rows = rows.filter((r) => Object.values(r).some((v) => String(v).toLowerCase().includes(s)));
    }
    if (sortKey === "__bySerie") {
      rows = [...rows].sort((a, b) => {
        const td = typeRank(a[colType]) - typeRank(b[colType]);
        if (td !== 0) return td;
        return parseInt(a[colPos]||99) - parseInt(b[colPos]||99);
      });
    } else if (sortKey === "__relPct") {
      rows = [...rows].sort((a, b) => {
        const an = relPct(a), bn = relPct(b);
        if (an === null && bn === null) return 0;
        if (an === null) return 1;
        if (bn === null) return -1;
        return sortDir === "asc" ? an - bn : bn - an;
      });
    } else if (sortKey) {
      rows = [...rows].sort((a, b) => {
        let av = a[sortKey], bv = b[sortKey];
        const an = pctNum(av), bn = pctNum(bv);
        if (an !== null && bn !== null) return sortDir === "asc" ? an - bn : bn - an;
        av = String(av || ""); bv = String(bv || "");
        return sortDir === "asc" ? av.localeCompare(bv) : bv.localeCompare(av);
      });
    }
    return rows;
  }, [data, selectedRegates, selectedJournees, selectedEpreuves, selectedTypes, search, sortKey, sortDir, bestPctByRace, colType]);

  const stats = useMemo(() => {
    if (!filteredRows.length || !colPct) return null;
    const withPct = filteredRows
      .map((r) => ({ row: r, pct: pctNum(r[colPct]) }))
      .filter((x) => x.pct !== null && x.pct > 30 && x.pct < 130);
    if (!withPct.length) return null;
    const avg = withPct.reduce((a, x) => a + x.pct, 0) / withPct.length;
    const best = withPct.reduce((a, b) => (b.pct > a.pct ? b : a));
    const worst = withPct.reduce((a, b) => (b.pct < a.pct ? b : a));
    return {
      avg,
      max: best.pct,
      min: worst.pct,
      count: filteredRows.length,
      bestEquipage: colEquipage ? best.row[colEquipage] : null,
      bestCat: colCat ? best.row[colCat] : null,
    };
  }, [filteredRows, colPct, colEquipage, colCat]);

  // Normalise le nom de club : supprime le numéro final (ex: "Nantes CAN 1" → "Nantes CAN")
  const normalizeClub = (club) => {
    if (!club) return "";
    return club.replace(/\s+\d+$/, "").trim();
  };

  // Classement clubs basé sur la colonne Points
  const clubsClassement = useMemo(() => {
    if (!colPts || !data) return [];
    const totaux = {};
    const details = {};
    data.rows.forEach((r) => {
      const club = normalizeClub(r[colClub]);
      if (!club) return;
      const pts = parseFloat(r[colPts]);
      if (isNaN(pts)) return;
      const epreuve = colEpreuve ? r[colEpreuve] : "?";
      const place = r["Place finale"] || r["Pos."] || "?";
      totaux[club] = (totaux[club] || 0) + pts;
      if (!details[club]) details[club] = [];
      details[club].push({ epreuve, place, pts });
    });
    return Object.entries(totaux)
      .map(([club, total]) => ({ club, total, details: details[club] || [] }))
      .sort((a, b) => b.total - a.total)
      .map((c, i) => ({ ...c, rank: i + 1 }));
  }, [data, colPts, colClub, colEpreuve]);

  // Liste des courses (libellé court) dans l'ordre d'apparition — sert de colonnes
  // dynamiques dans la vue par athlète (Bateau / % FFA / % Relatif par course).
  const raceList = useMemo(() => {
    const seen = [];
    const seenSet = new Set();
    filteredRows.forEach((r) => {
      const label = colRegate ? (regateMeta[r[colRegate]]?.short || r[colRegate]) : (r.__srcFile || "Course");
      if (label && !seenSet.has(label)) { seenSet.add(label); seen.push(label); }
    });
    return seen;
  }, [filteredRows, colRegate, regateMeta]);

  const raceColorByShort = useMemo(() => {
    const m = {};
    Object.values(regateMeta).forEach((v) => { m[v.short] = v.color; });
    return m;
  }, [regateMeta]);

  // Corrige les fautes d'orthographe sur les noms de rameurs : regroupe les
  // variantes proches (distance de Levenshtein faible) sous l'orthographe la
  // plus fréquente, en partant du principe que ce sont toujours les mêmes athlètes.
  // IMPORTANT : on ne fusionne jamais 2 noms associés à des sexes différents
  // (ex. CARON (F) et CARDON (H) restent bien distincts).
  const nameCorrectionMap = useMemo(() => {
    if (!colEquipage) return {};
    const counts = new Map();
    filteredRows.forEach((r) => {
      const catStr = colCat ? String(r[colCat] || "").trim() : "";
      const sex = catStr.startsWith("H") ? "H" : catStr.startsWith("F") ? "F" : "?";
      String(r[colEquipage] || "").split("/").map((n) => n.trim()).filter(Boolean).forEach((name) => {
        const key = name.toUpperCase();
        if (!counts.has(key)) counts.set(key, { count: 0, original: name, sexCounts: { H: 0, F: 0, "?": 0 } });
        const c = counts.get(key);
        c.count += 1;
        c.sexCounts[sex] += 1;
      });
    });
    const items = [...counts.entries()]
      .map(([key, v]) => ({
        key,
        name: v.original,
        count: v.count,
        sex: Object.entries(v.sexCounts).sort((a, b) => b[1] - a[1])[0][0],
      }))
      .sort((a, b) => b.count - a.count || a.key.localeCompare(b.key));

    const clusters = [];
    const remap = {};
    items.forEach((item) => {
      const found = clusters.find((cl) => {
        const maxDist = cl.canonicalKey.length <= 4 ? 1 : 2;
        const sexCompatible = cl.sex === "?" || item.sex === "?" || cl.sex === item.sex;
        if (!sexCompatible) return false;
        const closeTypo = Math.abs(cl.canonicalKey.length - item.key.length) <= maxDist && levenshtein(cl.canonicalKey, item.key) <= maxDist;
        const contained = isNameContained(cl.canonicalKey, item.key);
        return closeTypo || contained;
      });
      if (found) {
        // Si le nom rencontré est plus complet (ex. "MEZOUGHI AUGUSTE" vs "MEZOUGHI"),
        // on en fait la nouvelle référence et on met à jour toutes les occurrences
        // déjà remappées vers l'ancienne référence (moins complète).
        if (item.key.length > found.canonicalKey.length) {
          const oldCanonicalName = found.canonicalName;
          found.canonicalKey = item.key;
          found.canonicalName = item.name;
          Object.keys(remap).forEach((k) => { if (remap[k] === oldCanonicalName) remap[k] = item.name; });
        }
        remap[item.key] = found.canonicalName;
      } else {
        clusters.push({ canonicalKey: item.key, canonicalName: item.name, sex: item.sex });
        remap[item.key] = item.name;
      }
    });
    return remap;
  }, [filteredRows, colEquipage, colCat]);

  // Éclate chaque ligne "Équipage" (ex. "IMARD / KALHOUA") en athlètes individuels,
  // pour construire un classement par rameur sur la moyenne de leur % Relatif.
  const athleteEntries = useMemo(() => {
    if (!colEquipage) return [];
    const entries = [];
    filteredRows.forEach((r) => {
      const namesRaw = String(r[colEquipage] || "");
      if (!namesRaw.trim()) return;
      const names = namesRaw.split("/").map((n) => n.trim()).filter(Boolean);
      const catStr = colCat ? String(r[colCat] || "").trim() : "";
      const sex = catStr.startsWith("H") ? "H" : catStr.startsWith("F") ? "F" : "?";
      const pct = colPct ? pctNum(r[colPct]) : null;
      const rp = relPct(r);
      const regateLabel = colRegate ? (regateMeta[r[colRegate]]?.short || r[colRegate]) : (r.__srcFile || "");
      names.forEach((rawName) => {
        const correctedName = nameCorrectionMap[rawName.toUpperCase()] || rawName;
        entries.push({
          name: correctedName,
          key: correctedName.toUpperCase(),
          sex,
          regateShort: regateLabel,
          epreuve: colEpreuve ? r[colEpreuve] : "",
          bateau: colBateau ? r[colBateau] : "",
          temps: colTemps ? r[colTemps] : "",
          pct,
          relPct: rp,
        });
      });
    });
    return entries;
  }, [filteredRows, colEquipage, colCat, colPct, colRegate, colEpreuve, colBateau, colTemps, regateMeta, nameCorrectionMap]);

  const athleteSummary = useMemo(() => {
    const map = new Map();
    athleteEntries.forEach((e) => {
      if (!map.has(e.key)) map.set(e.key, { key: e.key, name: e.name, sex: e.sex, perfs: [], byRace: {} });
      const a = map.get(e.key);
      a.perfs.push(e);
      (a.byRace[e.regateShort] = a.byRace[e.regateShort] || []).push(e);
    });
    const list = [...map.values()].map((a) => {
      const validRel = a.perfs.map((p) => p.relPct).filter((v) => v !== null);
      const validPct = a.perfs.map((p) => p.pct).filter((v) => v !== null);
      return {
        ...a,
        avgRelPct: validRel.length ? validRel.reduce((s, v) => s + v, 0) / validRel.length : null,
        avgPct: validPct.length ? validPct.reduce((s, v) => s + v, 0) / validPct.length : null,
      };
    });
    const sortField = rankMode === "ffa" ? "avgPct" : "avgRelPct";
    list.sort((a, b) => {
      if (a[sortField] === null) return 1;
      if (b[sortField] === null) return -1;
      return b[sortField] - a[sortField];
    });
    return list;
  }, [athleteEntries, rankMode]);

  const toggleSort = (key) => {
    if (sortKey === key) setSortDir(sortDir === "asc" ? "desc" : "asc");
    else { setSortKey(key); setSortDir("asc"); }
  };

  const exportCSV = () => {
    const header = cols.join(",");
    const lines = filteredRows.map((r) => cols.map((c) => (String(r[c] || "").includes(",") ? `"${r[c]}"` : r[c])).join(","));
    const csv = "\uFEFF" + [header, ...lines].join("\n");
    const blob = new Blob([csv], { type: "text/csv;charset=utf-8;" });
    const a = document.createElement("a");
    a.href = URL.createObjectURL(blob);
    a.download = "resultats_filtres.csv";
    a.click();
  };

  return (
    <div onPaste={data ? handlePaste : undefined}>
      <div style={{ display: "flex", alignItems: "center", gap: 16, marginBottom: 20 }}>
        <img src="data:image/png;base64," alt="Logo CAN" style={{ height: 72, flexShrink: 0 }} />
        <div>
          <div className="header">
            <span className="eyebrow">Cercle de l'Aviron de Nantes</span>
          </div>
          <h1 style={{ margin: "4px 0 0" }}>Analyse régates vs pronostics DTN</h1>
        </div>
      </div>

      {!data && (
        <div
          className={"dropzone no-print" + (dragOver ? " drag" : "")}
          onPaste={handlePaste}
          onDragOver={(e) => { e.preventDefault(); setDragOver(true); }}
          onDragLeave={() => setDragOver(false)}
          onDrop={onDrop}
          tabIndex={0}
        >
          <p style={{ fontWeight: 600, fontSize: 16, margin: "0 0 6px" }}>Charger des résultats de régate</p>
          <p style={{ fontSize: 13, color: "var(--text-secondary)", maxWidth: 480, margin: "0 auto 10px" }}>
            Glisse un ou plusieurs fichiers ici, colle-en un (Ctrl+V), ou importe-les. Tu peux charger plusieurs
            courses à la suite pour comparer leurs % Relatifs. Formats acceptés :
          </p>
          <ul style={{ fontSize: 12.5, color: "var(--text-secondary)", maxWidth: 460, margin: "0 auto 20px", textAlign: "left", paddingLeft: 18 }}>
            <li>Un <b>CSV déjà traité</b> (colonnes % FFA - DTN, Top demi journée…) → ouverture directe</li>
            <li>Un <b>PDF brut de résultats CrewTimer</b> (impression de la page régate) → calcul automatique des % FFA-DTN</li>
            <li>Un <b>PDF "Classement"</b> déjà exporté par cette app → ouverture directe</li>
            <li>Un <b>texte brut collé</b> depuis la page CrewTimer → calcul automatique</li>
          </ul>
          <div style={{ display: "flex", gap: 8, justifyContent: "center", flexWrap: "wrap" }}>
            <button className="primary" onClick={() => fileRef.current?.click()}>Importer des fichiers (CSV/PDF)</button>
            <button onClick={() => loadCSV(SAMPLE_CSV, "Exemple")}>Voir un exemple</button>
            <button onClick={() => { setFormBassin(BASSIN_VIDE); setFormBassinMode("add"); setShowBassinsModal(true); }}>🏊 Gérer les bassins</button>
          </div>
          <input ref={fileRef} type="file" accept=".csv,text/csv,.pdf,application/pdf" multiple onChange={(e) => handleFile(e.target.files)} style={{ display: "none" }} />
          {error && <p style={{ color: "#993C1D", fontSize: 13, marginTop: 14 }}>{error}</p>}
        </div>
      )}

      {activeRawItem && (
        <div style={{ position: "fixed", inset: 0, background: "rgba(0,0,0,0.35)", display: "flex", alignItems: "center", justifyContent: "center", zIndex: 50 }}>
          <div style={{ background: "var(--bg-primary)", borderRadius: 12, padding: 24, width: 360, maxWidth: "90vw" }}>
            <p style={{ fontWeight: 600, fontSize: 15, margin: "0 0 6px" }}>Nom de la course</p>
            <p style={{ fontSize: 12.5, color: "var(--text-secondary)", margin: "0 0 12px" }}>
              Fichier "{activeRawItem.fileLabel}" — résultats bruts détectés, calcul automatique du % FFA-DTN.
              {rawQueue.length > 0 && ` (${rawQueue.length} autre${rawQueue.length > 1 ? "s" : ""} en attente)`}
            </p>
            <input
              type="text"
              autoFocus
              placeholder="Ex : RS2 U19 vendredi matin"
              value={regateNameInput}
              onChange={(e) => setRegateNameInput(e.target.value)}
              onKeyDown={(e) => e.key === "Enter" && !rawProcessing && confirmRawItem()}
              style={{ width: "100%", marginBottom: 16 }}
            />
            <p style={{ fontWeight: 600, fontSize: 13, margin: "0 0 6px" }}>Distance de course</p>
            <p style={{ fontSize: 12.5, color: "var(--text-secondary)", margin: "0 0 10px" }}>
              Les temps seront convertis en équivalent 2000m avant calcul du % FFA - DTN.
            </p>
            <div style={{ display: "flex", gap: 6, marginBottom: 16 }}>
              {[1000, 1500, 2000].map((d) => (
                <button
                  key={d}
                  onClick={() => setRaceDistance(d)}
                  style={{
                    flex: 1,
                    background: raceDistance === d ? "var(--accent)" : "var(--bg-primary)",
                    color: raceDistance === d ? "white" : "var(--text-primary)",
                    borderColor: raceDistance === d ? "var(--accent)" : "var(--border-strong)",
                    fontWeight: raceDistance === d ? 600 : 400,
                  }}
                >
                  {d}m
                </button>
              ))}
            </div>
            <div style={{ display: "flex", gap: 8, justifyContent: "flex-end" }}>
              <button onClick={cancelRawItem} disabled={rawProcessing}>Annuler</button>
              <button className="primary" onClick={confirmRawItem} disabled={rawProcessing}>
                {rawProcessing ? "Traitement…" : "Lancer le traitement"}
              </button>
            </div>
          </div>
        </div>
      )}

      {/* ── Modale gestion des bassins ── */}
      {showBassinsModal && (
        <div style={{ position: "fixed", inset: 0, background: "rgba(0,0,0,0.4)", display: "flex", alignItems: "center", justifyContent: "center", zIndex: 60 }}>
          <div style={{ background: "var(--bg-primary)", borderRadius: 14, padding: 24, width: 540, maxWidth: "95vw", maxHeight: "90vh", overflowY: "auto" }}>
            <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center", marginBottom: 16 }}>
              <p style={{ fontWeight: 700, fontSize: 16, margin: 0 }}>Gérer les bassins</p>
              <button onClick={() => setShowBassinsModal(false)} style={{ border: "none", background: "transparent", fontSize: 20, cursor: "pointer", color: "var(--text-tertiary)" }}>✕</button>
            </div>

            {/* Formulaire ajouter / modifier */}
            <div style={{ background: "var(--bg-secondary)", borderRadius: 10, padding: 16, marginBottom: 20 }}>
