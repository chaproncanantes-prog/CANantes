                                const site = allSites[meteoSite];
                                const veilleStr = dateMinusN(meteoDate, 1);
                                const [horairesJour, horairesVeille] = await Promise.all([
                                  fetchMeteoHoraire(site.lat, site.lon, meteoDate),
                                  fetchMeteoHoraire(site.lat, site.lon, veilleStr),
                                ]);
                                const [hh, mm] = meteoHeure.split(":").map(Number);
                                const courseTarget = `${meteoDate}T${String(hh).padStart(2,"0")}:${String(mm).padStart(2,"0")}`;
                                const closest = horairesJour.reduce((a, b) =>
                                  Math.abs(new Date(b.time) - new Date(courseTarget)) < Math.abs(new Date(a.time) - new Date(courseTarget)) ? b : a
                                );
                                const tAirVeilleMoy = horairesVeille.reduce((s, h) => s + h.temp, 0) / horairesVeille.length;
