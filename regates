// ============================================================
// CORRECTION MÉTÉO — coefficients Kleshnev / Filter (littérature)
// À recalibrer avec les données empiriques du club dès que possible.
// Référence standard : vent = 0 m/s, eau = 26°C (Frontiers Sports 2023)
// ============================================================
const COEF_VENT_BATEAU = { "1x": -1.6, "2x": -1.3, "2-": -1.3, "4x": -1.1, "4-": -1.1, "4+": -1.0, "8+": -0.9 };
const COEF_VENT_DEFAUT = -1.2;
const COEF_TEMP_EAU = 0.12;   // %/°C
const TEMP_EAU_REF = 26.0;    // °C

// Sites connus : lat, lon, azimut du parcours (cap du sens "aller" en degrés)
const SITES_METEO = {
  "vaires_sur_marne": { label: "Vaires-sur-Marne (Bassin olympique)", lat: 48.8616, lon: 2.6453, azimut: 100 },
  "nantes_erdre":     { label: "Nantes (Erdre)",                       lat: 47.2625, lon: -1.5469, azimut: 0 },
};

// Appel Open-Meteo (archive ou forecast selon l'âge de la date)
const fetchMeteoHoraire = async (lat, lon, dateStr) => {
  const today = new Date();
  const raceDate = new Date(dateStr);
  const daysAgo = Math.round((today - raceDate) / 86400000);
  const useArchive = daysAgo > 5;
  const base = useArchive
    ? "https://archive-api.open-meteo.com/v1/archive"
    : "https://api.open-meteo.com/v1/forecast";
  const params = new URLSearchParams({
    latitude: lat, longitude: lon,
    hourly: "temperature_2m,wind_speed_10m,wind_direction_10m,shortwave_radiation",
    start_date: dateStr, end_date: dateStr,
    timezone: "Europe/Paris", wind_speed_unit: "ms",
  });
  const r = await fetch(`${base}?${params}`);
  if (!r.ok) throw new Error(`Open-Meteo ${r.status}`);
  const h = (await r.json()).hourly;
  // Retourne un tableau d'objets indexés par heure
  return h.time.map((t, i) => ({
    time: t,
    temp: h.temperature_2m[i],
    windSpeed: h.wind_speed_10m[i],
    windDir: h.wind_direction_10m[i],
    radiation: h.shortwave_radiation[i],
  }));
};

// Composante de vent de face/dos dans l'axe du parcours
const ventFaceParcours = (windSpeed, windDirFrom, azimutParcours) => {
  const windTo = (windDirFrom + 180) % 360;
  const delta = (windTo - azimutParcours) * Math.PI / 180;
  return -windSpeed * Math.cos(delta);
};

// Estimation T_eau de surface — lac peu profond stagnant
// Modèle : réponse thermique ≈ 1 jour (littérature Agamon Hula 2025)
// T_eau ≈ 0.60×T_air_veille_moy + 0.25×T_air_heure_course + 0.15×(radiation_veille_moy/100) + offset_saison
const estimerTempEau = (tAirVeilleMoy, radiationVeilleMoy, tAirCourse, dateStr) => {
  const d = new Date(dateStr);
  const debut = new Date(d.getFullYear(), 0, 0);
  const jourAnnee = Math.round((d - debut) / 86400000);
  const offsetSaison = 3.0 * Math.cos(2 * Math.PI * (jourAnnee - 220) / 365);
  const tEau = 0.60 * tAirVeilleMoy + 0.25 * tAirCourse + 0.15 * (radiationVeilleMoy / 100) + offsetSaison;
  return Math.round(tEau * 10) / 10;
};

// Décale une date de N jours (retourne "YYYY-MM-DD")
const dateMinusN = (dateStr, n) => {
  const d = new Date(dateStr);
  d.setDate(d.getDate() - n);
  return d.toISOString().slice(0, 10);
};

// Calcule l'azimut (cap en degrés) du point A vers le point B
const calculerAzimut = (latD, lonD, latA, lonA) => {
  const toR = d => d * Math.PI / 180;
  const dLon = toR(lonA - lonD);
  const y = Math.sin(dLon) * Math.cos(toR(latA));
  const x = Math.cos(toR(latD)) * Math.sin(toR(latA)) - Math.sin(toR(latD)) * Math.cos(toR(latA)) * Math.cos(dLon);
  return Math.round(((Math.atan2(y, x) * 180 / Math.PI) + 360) % 360);
};

// Estimation T_eau selon le type de plan d'eau
// lac         → modèle surface (rayonnement dominant, réponse 1 jour)
// riviere_*   → formule Stefan 1993 (T_air dominant, rivière renouvelle l'eau)
const estimerTempEauParType = (type, tAirVeilleMoy, radVeilleMoy, tAirCourse, dateStr) => {
  if (type === "lac") {
    const d = new Date(dateStr);
    const jourAnnee = Math.round((d - new Date(d.getFullYear(), 0, 0)) / 86400000);
    const offsetSaison = 3.0 * Math.cos(2 * Math.PI * (jourAnnee - 220) / 365);
    return Math.round((0.60 * tAirVeilleMoy + 0.25 * tAirCourse + 0.15 * (radVeilleMoy / 100) + offsetSaison) * 10) / 10;
  } else {
    // Rivière (calme ou courant) : formule Stefan 1993 — T_air veille domine
    return Math.round((5.0 + 0.75 * tAirVeilleMoy) * 10) / 10;
  }
};

// Correction courant : retire l'effet du courant sur le chrono
// courantMs > 0 = courant dans le sens de la course (aval, favorable)
// courantMs < 0 = courant contre la course (amont, pénalisant)
const correctionCourant = (timeSec, distM, courantMs) => {
  if (!courantMs) return timeSec;
  const vBrute = distM / timeSec;            // vitesse bateau mesurée (m/s)
  const vReelle = vBrute - courantMs;        // vitesse réelle dans l'eau sans courant
  if (vReelle <= 0.5) return null;           // cas aberrant (courant > vitesse bateau)
  return distM / vReelle;                    // temps sans courant
};

