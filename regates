<script type="text/babel" data-presets="react">
const { useState, useMemo, useRef, useEffect } = React;

const SAMPLE_CSV = `Régate,Journée,Épreuve,Type,Pos.,Équipage,Nage/Barreur,Bateau,Catégorie DTN,Temps réalisé,Référence DTN,% FFA - DTN,Top demi journée,Écart vs Top demi journée
Cazaubon Sud-Ouest 2026,Samedi Matin (PCM),U17H 2-,PCM,1,TOULOUSE AT 1,GASCOIN Arthur - LOUGNON Antonin,2-,H U19,06:40.44,06:19.00,94.65%,94.65%,+0.00%
Cazaubon Sud-Ouest 2026,Samedi Matin (PCM),U17H 2-,PCM,2,BAYONNE AB 1,DE FRITSCH Gauthier - DELMAS Oscar,2-,H U19,07:23.34,06:19.00,85.49%,94.65%,+9.16%
Cazaubon Sud-Ouest 2026,Samedi Après-midi (Ligne),SH 1x,D1-Série1,1,VILLENEUVE AV 1,GRESSE Simon,1x,H SA,07:20.86,06:28.00,88.42%,88.42%,+0.00%`;

const parseCSV = (text) => {
  const lines = text.replace(/^\uFEFF/, "").trim().split(/\r?\n/);
  if (lines.length < 2) return { headers: [], rows: [] };
  const parseLine = (line) => {
    const cells = [];
    let cur = "";
    let inQuotes = false;
    for (let i = 0; i < line.length; i++) {
      const c = line[i];
      if (c === '"') {
        if (inQuotes && line[i + 1] === '"') { cur += '"'; i++; }
        else inQuotes = !inQuotes;
      } else if (c === "," && !inQuotes) {
        cells.push(cur); cur = "";
      } else cur += c;
    }
    cells.push(cur);
    return cells;
  };
  const headers = parseLine(lines[0]).map((h) => h.trim());
  const rows = lines.slice(1).filter((l) => l.trim()).map((line) => {
    const cells = parseLine(line);
    const obj = {};
    headers.forEach((h, i) => (obj[h] = (cells[i] || "").trim()));
    return obj;
  });
  return { headers, rows };
};

// Distance de Levenshtein — sert à regrouper les fautes de frappe sur les noms
// de rameurs (ex. "Bonnln" / "Bonnin") sous une seule orthographe.
const levenshtein = (a, b) => {
  const m = a.length, n = b.length;
  const dp = Array.from({ length: m + 1 }, () => new Array(n + 1).fill(0));
  for (let i = 0; i <= m; i++) dp[i][0] = i;
  for (let j = 0; j <= n; j++) dp[0][j] = j;
  for (let i = 1; i <= m; i++) {
    for (let j = 1; j <= n; j++) {
      dp[i][j] = a[i - 1] === b[j - 1] ? dp[i - 1][j - 1] : 1 + Math.min(dp[i - 1][j - 1], dp[i - 1][j], dp[i][j - 1]);
    }
  }
  return dp[m][n];
};

// Vrai si tous les mots du nom le plus court se retrouvent dans le nom le plus
// long (ex. "MEZOUGHI" est entièrement contenu dans "MEZOUGHI AUGUSTE") — sert à
// fusionner un nom tronqué et sa version complète, ce que la distance de
// Levenshtein seule ne peut pas rattraper (trop de caractères d'écart).
const isNameContained = (a, b) => {
  const wa = a.split(" ").filter(Boolean);
  const wb = b.split(" ").filter(Boolean);
  const [shorter, longer] = wa.length <= wb.length ? [wa, wb] : [wb, wa];
  if (shorter.length === 0 || shorter.length === longer.length) return false;
  return shorter.every((w) => longer.includes(w));
};

const pctNum = (s) => {
  if (!s) return null;
  const n = parseFloat(String(s).replace("%", "").replace(",", "."));
  return isNaN(n) ? null : n;
};

if (window.pdfjsLib) {
  pdfjsLib.GlobalWorkerOptions.workerSrc = "https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js";
}

// Parse un export "Classement" du dashboard (PDF) en s'appuyant sur la POSITION
// (x, y) des mots plutôt que sur l'ordre du texte linéaire. Nécessaire car la
// cellule "Épreuve" est rendue sur 2 lignes (le code épreuve au-dessus de la
// ligne de données, "Série" en dessous), ce qui casse une lecture ligne par ligne.
const HEADER_LABELS = {
  "Rang": "rang", "Journée": "journee", "Épreuve": "epreuve",
  "Équipage": "equipage", "Bateau": "bateau", "Catégorie": "categorie",
  "Temps": "temps", "Écart": "ecart",
};
const REQUIRED_COLS = ["rang", "journee", "epreuve", "equipage", "bateau", "categorie", "temps", "ecart"];

const parsePdfClassementColumns = async (arrayBuffer) => {
  const pdf = await pdfjsLib.getDocument({ data: arrayBuffer }).promise;
  let regateTitle = "Course PDF";
  let lastCols = null; // { xs, names }
  const dataRows = [];

  for (let p = 1; p <= pdf.numPages; p++) {
    const page = await pdf.getPage(p);
    const content = await page.getTextContent();
    // top = distance depuis le haut de page (axe inversé par rapport au repère PDF natif).
    // On éclate chaque item en mots individuels avec une position x interpolée le long
    // de sa largeur, car pdf.js peut regrouper plusieurs mots dans un même item selon
    // le moteur d'export PDF utilisé (on ne peut pas supposer un découpage mot-par-mot).
    const words = [];
    content.items.forEach((it) => {
      const str = it.str;
      if (!str || !str.trim()) return;
      const x0 = it.transform[4];
      const top = -it.transform[5];
      const width = typeof it.width === "number" && it.width > 0 ? it.width : 0;
      const totalLen = str.length || 1;
      let offset = 0;
      str.split(/(\s+)/).forEach((tok) => {
        if (tok.trim()) {
          const tokX = width ? x0 + (offset / totalLen) * width : x0;
          words.push({ text: tok.trim(), x: tokX, top });
        }
        offset += tok.length;
      });
    });
    console.log(`[PDF parse] page ${p}/${pdf.numPages} — ${content.items.length} items pdf.js, ${words.length} mots reconstruits`);

    if (p === 1) {
      const sorted = [...words].sort((a, b) => a.top - b.top);
      const lineGroups = [];
      let cur = null;
      sorted.forEach((w) => {
        if (cur && Math.abs(w.top - cur.top) < 1) cur.words.push(w);
        else { cur = { top: w.top, words: [w] }; lineGroups.push(cur); }
      });
      const lineTexts = lineGroups.map((l) => l.words.sort((a, b) => a.x - b.x).map((w) => w.text).join(" "));
      const ci = lineTexts.findIndex((t) => /Classement par % FFA/i.test(t));
      if (ci > 0) regateTitle = lineTexts[ci - 1];
    }

    const rangWord = words.find((w) => w.text === "Rang");
    const headerTop = rangWord ? rangWord.top : null;
    const headerX = {};
    let pctX = null;
    if (headerTop !== null) {
      words.forEach((w) => {
        if (Math.abs(w.top - headerTop) > 2) return;
        if (HEADER_LABELS[w.text] && !(HEADER_LABELS[w.text] in headerX)) headerX[HEADER_LABELS[w.text]] = w.x;
        if (w.text === "%" && pctX === null) pctX = w.x;
      });
    }

    let xs, names, contentStartTop;
    if (headerTop !== null && REQUIRED_COLS.every((k) => k in headerX)) {
      const entries = Object.entries(headerX);
      if (pctX !== null) entries.push(["pct", pctX]);
      entries.sort((a, b) => a[1] - b[1]);
      xs = entries.map((e) => e[1]);
      names = entries.map((e) => e[0]);
      lastCols = { xs, names };
      contentStartTop = headerTop + 5;
      console.log(`[PDF parse] page ${p} : en-tête détecté, colonnes =`, names);
    } else if (lastCols) {
      xs = lastCols.xs; names = lastCols.names; contentStartTop = -Infinity;
      console.log(`[PDF parse] page ${p} : pas d'en-tête, réutilisation des colonnes de la page précédente`);
    } else {
      console.log(`[PDF parse] page ${p} : pas d'en-tête et aucune colonne connue → page ignorée`);
      continue;
    }

    const colForX = (x) => {
      for (let i = 0; i < xs.length; i++) {
        const lo = xs[i] - 5;
        const hi = i + 1 < xs.length ? xs[i + 1] - 5 : Infinity;
        if (x >= lo && x < hi) return names[i];
      }
      return null;
    };

    const rangLo = xs[names.indexOf("rang")] - 5;
    const rangHi = xs[names.indexOf("journee")] - 5;
    let anchors = words
      .filter((w) => w.top > contentStartTop && w.x >= rangLo && w.x < rangHi && /^\d+$/.test(w.text))
      .sort((a, b) => a.top - b.top);

    if (anchors.length === 0) {
      // Repli : sur une page de continuation, les positions x héritées de la page
      // précédente peuvent légèrement décaler (marges, mise en page). On détecte
      // alors le rang comme le mot le plus à gauche de chaque ligne, sans dépendre
      // de coordonnées x calibrées au préalable.
      const byTop = new Map();
      words.forEach((w) => {
        if (w.top <= contentStartTop) return;
        const key = Math.round(w.top);
        if (!byTop.has(key) || w.x < byTop.get(key).x) byTop.set(key, w);
      });
      anchors = [...byTop.values()].filter((w) => /^\d+$/.test(w.text)).sort((a, b) => a.top - b.top);
      console.log(`[PDF parse] page ${p} : repli détection rang (mot le plus à gauche) → ${anchors.length} ligne(s)`);
    }
    console.log(`[PDF parse] page ${p} : ${anchors.length} ligne(s) détectée(s) — rangs =`, anchors.map((a) => a.text).join(", "));

    anchors.forEach((a, idx) => {
      const topMid = idx > 0 ? (anchors[idx - 1].top + a.top) / 2 : a.top - 15;
      const botMid = idx + 1 < anchors.length ? (anchors[idx + 1].top + a.top) / 2 : a.top + 15;
      const rowWords = words.filter((w) => w.top >= topMid && w.top < botMid && w.top > contentStartTop);
      const byCol = {};
      rowWords.forEach((w) => {
        const c = colForX(w.x);
        if (!c) return;
        (byCol[c] = byCol[c] || []).push(w.text);
      });
      let epreuveStr = (byCol.epreuve || []).filter((t) => t !== "Série").join(" ");
      if (!epreuveStr) {
        // Filet de sécurité (ex. ligne à cheval entre 2 pages) : reconstruit
        // l'épreuve à partir du sexe (catégorie) et du type de bateau.
        const catStr = (byCol.categorie || []).join(" ");
        const bateauStr = (byCol.bateau || []).join(" ");
        const prefix = catStr.startsWith("H") ? "JM" : catStr.startsWith("F") ? "JW" : "";
        epreuveStr = prefix && bateauStr ? `${prefix} ${bateauStr}` : "";
      }
      dataRows.push({
        "Régate": regateTitle,
        "Journée": (byCol.journee || []).join(" "),
        "Épreuve": epreuveStr,
        "Type": "Série",
        "Pos.": a.text,
        "Équipage": (byCol.equipage || []).join(" "),
        "Nage/Barreur": "",
        "Bateau": (byCol.bateau || []).join(" "),
        "Catégorie DTN": (byCol.categorie || []).join(" "),
        "Temps réalisé": (byCol.temps || []).join(" "),
        "Référence DTN": "",
        "% FFA - DTN": (byCol.pct || []).join(" "),
        "Écart vs Top demi journée": (byCol.ecart || []).join(" "),
      });
    });
  }

  if (dataRows.length === 0) return { headers: [], rows: [] };

  const best = Math.max(...dataRows.map((r) => pctNum(r["% FFA - DTN"])).filter((v) => v !== null));
  dataRows.forEach((r) => { r["Top demi journée"] = best ? `${best.toFixed(2)}%` : ""; });

  const headers = ["Régate", "Journée", "Épreuve", "Type", "Pos.", "Équipage", "Nage/Barreur", "Bateau",
    "Catégorie DTN", "Temps réalisé", "Référence DTN", "% FFA - DTN", "Top demi journée", "Écart vs Top demi journée"];
  return { headers, rows: dataRows };
};

// Stratégie de repli : reconstruit le texte page par page en lignes (regroupement
// par proximité verticale), puis applique des regex sur le texte linéaire. Sert de
// filet de sécurité si la stratégie par positions de colonnes ne trouve aucune ligne
// (mise en page PDF légèrement différente selon le moteur d'export du navigateur).
const ROW_A_RE = /^(\d+)\s+(.+?)\s+((?:JM|JW)\s*(?:1x|2x|4x|8\+|4\+|2\+|2-|4-))$/;
const ROW_B_RE = /^Série\s+(.+?)\s+(1x|2x|4x|8\+|4\+|2\+|2-|4-)\s+(H|F)\s*(U\d+|SA|SB|SC|SH|SJ)\s+(\d{1,2}:\d{2}\.\d{2,3})\s+(\d{1,3}(?:[.,]\d{1,2})?)%\s+(—|\+\d{1,2}(?:[.,]\d{1,2})?%)\s*$/;

const parsePdfClassementLines = async (arrayBuffer) => {
  const pdf = await pdfjsLib.getDocument({ data: arrayBuffer }).promise;
  const lines = [];
  for (let p = 1; p <= pdf.numPages; p++) {
    const page = await pdf.getPage(p);
    const content = await page.getTextContent();
    const byTop = [];
    content.items.forEach((it) => {
      const str = it.str.trim();
      if (!str) return;
      const top = Math.round(-it.transform[5]);
      const x = it.transform[4];
      let bucket = byTop.find((b) => Math.abs(b.top - top) <= 1);
      if (!bucket) { bucket = { top, items: [] }; byTop.push(bucket); }
      bucket.items.push({ x, str });
    });
    byTop.sort((a, b) => a.top - b.top).forEach((b) => {
      const line = b.items.sort((a, c) => a.x - c.x).map((i) => i.str).join(" ").replace(/\s+/g, " ").trim();
      if (line) lines.push(line);
    });
  }

  let regateTitle = "Course PDF";
  const titleIdx = lines.findIndex((l) => /Classement par % FFA/i.test(l));
  if (titleIdx > 0) regateTitle = lines[titleIdx - 1];

  const rows = [];
  for (let i = 0; i < lines.length - 1; i++) {
    const a = lines[i].match(ROW_A_RE);
    if (!a) continue;
    const b = lines[i + 1].match(ROW_B_RE);
    if (!b) continue;
    rows.push({
      "Régate": regateTitle,
      "Journée": a[2],
      "Épreuve": a[3],
      "Type": "Série",
      "Pos.": a[1],
      "Équipage": b[1],
      "Nage/Barreur": "",
      "Bateau": b[2],
      "Catégorie DTN": `${b[3]} ${b[4]}`,
      "Temps réalisé": b[5],
      "Référence DTN": "",
      "% FFA - DTN": `${b[6]}%`,
      "Écart vs Top demi journée": b[7],
    });
    i++;
  }

  if (rows.length === 0) return { headers: [], rows: [] };

  const best = Math.max(...rows.map((r) => pctNum(r["% FFA - DTN"])).filter((v) => v !== null));
  rows.forEach((r) => { r["Top demi journée"] = best ? `${best.toFixed(2)}%` : ""; });

  const headers2 = ["Régate", "Journée", "Épreuve", "Type", "Pos.", "Équipage", "Nage/Barreur", "Bateau",
    "Catégorie DTN", "Temps réalisé", "Référence DTN", "% FFA - DTN", "Top demi journée", "Écart vs Top demi journée"];
  return { headers: headers2, rows };
};

// Essaie d'abord la méthode par positions de colonnes (la plus précise), puis se
// rabat sur la méthode ligne-par-ligne si elle ne trouve rien. Chaque tentative
// reçoit sa PROPRE copie du buffer : pdf.js peut "détacher" (transférer) le
// buffer original lors de son utilisation, ce qui le rend inutilisable pour
// une 2e lecture si on ne le clone pas à chaque fois.
const parsePdfClassement = async (arrayBuffer) => {
  const byColumns = await parsePdfClassementColumns(arrayBuffer.slice(0));
  if (byColumns.rows.length > 0) return byColumns;
  return await parsePdfClassementLines(arrayBuffer.slice(0));
};

const fieldColor = (pct) => {
  if (pct === null) return "#888780";
  if (pct < 2) return "#0F6E56";
  if (pct <= 4) return "#854F0B";
  return "#993C1D";
};
const fieldBg = (pct) => {
  if (pct === null) return "transparent";
  if (pct < 2) return "#E1F5EE";
  if (pct <= 4) return "#FAEEDA";
  return "#FAECE7";
};

// ============================================================
// MOTEUR DE TRAITEMENT BRUT — Référentiel DTN + Parsing CrewTimer/PDF
// (porté depuis regatta_dashboard_15.html pour n'avoir qu'une seule app)
