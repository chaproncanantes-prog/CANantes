const DTN_REF = {
  "1x": { "H SA": 388, "H U23": 394, "H U19": 402, "H U19B": 408, "F SA": 426, "F U23": 432, "F U19": 441, "F U19B": 448 },
  "2x": { "H SA": 357, "H U23": 362, "H U19": 370, "H U19B": 376, "F SA": 395, "F U23": 401, "F U19": 409, "F U19B": 416 },
  "4x": { "H SA": 330, "H U23": 335, "H U19": 342, "H U19B": 347, "F SA": 363, "F U23": 369, "F U19": 377, "F U19B": 382 },
  "2-": { "H SA": 366, "H U23": 372, "H U19": 379, "H U19B": 385, "F SA": 405, "F U23": 411, "F U19": 420, "F U19B": 426 },
  "4-": { "H SA": 335, "H U23": 340, "H U19": 347, "H U19B": 353, "F SA": 372, "F U23": 378, "F U19": 386, "F U19B": 391 },
  "8+": { "H SA": 316, "H U23": 321, "H U19": 328, "H U19B": 333, "F SA": 351, "F U23": 356, "F U19": 364, "F U19B": 369 },
};

const round2 = (n) => Math.round(n * 100) / 100;

const parseTimeStr = (t) => {
  if (!t) return null;
  const s = t.trim().replace(",", ".");
  if (/^(DNS|DNF|SCR|DQ|ABD|Fini)$/i.test(s)) return null;
  const m = s.match(/^(\d{1,2}):(\d{1,2}(?:\.\d+)?)$/);
  if (m) return parseFloat(m[1]) * 60 + parseFloat(m[2]);
  return null;
};

const fmtTimeStr = (sec) => {
  if (sec === null || sec === undefined) return "";
  const m = Math.floor(sec / 60);
  const s = sec % 60;
  return `${String(m).padStart(2, "0")}:${s.toFixed(2).padStart(5, "0")}`;
};

const detectBoatCode = (eventName) => {
  const n = eventName.toUpperCase();
  const order = ["8+", "4-", "4X", "4+", "2-", "2X", "2+", "1X"];
  const map = { "8+": "8+", "4-": "4-", "4X": "4x", "4+": "4-", "2-": "2-", "2X": "2x", "2+": "2-", "1X": "1x" };
  for (const pat of order) {
    if (n.includes(pat)) return map[pat];
  }
  return null;
};

const detectCategoryCode = (eventName) => {
  const n = eventName.toUpperCase();
  let sexe = "H";
  if (/\bJW\d*\b/.test(n)) sexe = "F";
  else if (/\bJM\d*\b/.test(n)) sexe = "H";
  else if (/\bSF\b/.test(n) || /(?:U\d+)F/.test(n) || /DAME|FEMME/.test(n)) sexe = "F";
  else if (/\bSH\b/.test(n)) sexe = "H";

  let cat = "SA";
  if (/\bJM\d*\b|\bJW\d*\b/.test(n)) cat = "U19";
  else if (/U13|U15|U17/.test(n)) cat = "U19";
  else if (/U19B/.test(n)) cat = "U19B";
  else if (/U19/.test(n)) cat = "U19";
  else if (/U23/.test(n)) cat = "U23";
  else if (/\bSF\b|\bSH\b|SENIOR/.test(n)) cat = "SA";
  return `${sexe} ${cat}`;
};

const detectRaceType = (line) => {
  if (/Finale\s+A\b/i.test(line)) return "Finale A";
  if (/Finale\s+B\b/i.test(line)) return "Finale B";
  if (/Finale\s+C\b/i.test(line)) return "Finale C";
  if (/1\/2\s*Finale/i.test(line)) return "Demi-Finale";
  if (/\bDemi\b/i.test(line)) return "Demi-Finale";
  if (/\bQuart\b/i.test(line)) return "Quart de Finale";
  if (/\bTiers\b/i.test(line)) return "Tiers";
  if (/PCM/i.test(line)) return "Série PCM";
  return "Série";
};

const detectSession = (text) => {
  const m = text.match(/^(Vendredi|Samedi|Dimanche|Lundi)\s+(matin|ap[.\s]?midi|après[\s-]?midi|apres[\s-]?midi)/i);
  if (m) {
    const jour = m[1][0].toUpperCase() + m[1].slice(1).toLowerCase();
    const moment = /matin/i.test(m[2]) ? "Matin" : "Après-midi";
    return `${jour} ${moment}`;
  }
  return null;
};

const computeDtnFields = (rawRows, regateName, distance) => {
  const dist = distance || 2000;
  const factor = 2000 / dist;

  const enriched = rawRows.map((r) => {
    const refSec = r.boat && DTN_REF[r.boat] ? DTN_REF[r.boat][r.cat] : null;
    const actualSecRaw = parseTimeStr(r.finish);
    const actualSec = actualSecRaw !== null ? actualSecRaw * factor : null;
    const ratio = actualSec && refSec ? round2((refSec / actualSec) * 100) : null;
    return { ...r, refSec, actualSec, actualSecRaw, ratio };
  });

  const sessions = [...new Set(enriched.map((r) => r.session || "Journée unique"))];
  const topBySession = {};
  sessions.forEach((s) => {
    const valid = enriched.filter((r) => (r.session || "Journée unique") === s && r.ratio !== null && r.ratio > 30 && r.ratio < 130);
    topBySession[s] = valid.length ? Math.max(...valid.map((r) => r.ratio)) : null;
  });

  return enriched.map((r) => {
    const sessionKey = r.session || "Journée unique";
    const top = topBySession[sessionKey];
    const gap = top !== null && r.ratio !== null && r.ratio > 30 && r.ratio < 130 ? round2(top - r.ratio) : null;
    const result = {
      "Régate": regateName,
      "Journée": sessionKey,
      "Épreuve": r.event,
      "Type": r.type,
      "Pos.": r.pos,
      "Équipage": r.equipage,
      "Nage/Barreur": r.barreur || "",
      "Bateau": r.boat || "?",
      "Catégorie DTN": r.cat,
      "Distance": `${dist}m`,
      "Temps réalisé": r.finish,
    };
    if (dist !== 2000) {
      result["Temps équiv. 2000m"] = r.actualSec !== null ? fmtTimeStr(r.actualSec) : "";
    }
    result["Référence DTN"] = r.refSec !== null ? fmtTimeStr(r.refSec) : "";
    result["% FFA - DTN"] = r.ratio !== null ? `${r.ratio.toFixed(2)}%` : "";
    result["Top demi journée"] = top !== null ? `${top.toFixed(2)}%` : "";
    result["Écart vs Top demi journée"] = gap !== null ? `+${gap.toFixed(2)}%` : "";
    return result;
  });
};

const parseCrewTimerRawText = (text, regateName, distance) => {
  const rows = [];
  let currentEvent = "", currentBoat = null, currentCat = "", currentType = "Série", currentSession = null;
  const lines = text.split(/\r?\n/);

  for (let idx = 0; idx < lines.length; idx++) {
    const line = lines[idx].trim();
    if (!line) continue;

    const sess = detectSession(line);
    if (sess) currentSession = sess;

    const courseMatch = line.match(/(?:Course|Serie|Série|Finale|1\/2\s*Finale)[^:]*?\s+(?:n°\d+\s+)?(?:(?:Série|Serie|Demi|Finale|Quart|Tiers)\s+(?:[AB/C]*\s+)?(?:n°\d+\s+)?)?([A-Z][A-Z0-9\-+x /]+?)(?:\s+(?:Crit|PCM|PR\d+)|\s*\(|\s*$)/i);
    if (courseMatch && /Série|Course|Finale|Demi|Quart|Tiers/i.test(line)) {
      currentEvent = courseMatch[1].trim();
      currentBoat = detectBoatCode(currentEvent);
      currentCat = detectCategoryCode(currentEvent);
      currentType = detectRaceType(line);
      continue;
    }

    if (/^(?:Pos\.|Officiel|Non officiel|CrewTimer|Tous|Nage|Temps|brut|Ajust|Search)/i.test(line)) continue;

    const m = line.match(/^(\d+)\s+(.+)/);
    if (m && currentEvent) {
      const pos = m[1];
      const rest = m[2];
      const times = [...rest.matchAll(/\b(\d{1,2}:\d{2}\.\d{2})\b/g)].map((x) => x[1]);
      if (!times.length) continue;
      let finish = times[times.length - 1];
      if (times.length >= 2 && /^0\d:/.test(times[times.length - 1])) {
        finish = times[times.length - 2];
      }
      const fs = parseTimeStr(finish);
      if (fs !== null && (fs < 60 || fs > 1500)) continue;

      const fileMatch = rest.match(/\t(V\d+|\d+)\t/) || rest.match(/\s+(V\d+)\s+/);
      let equipage, barreur = "";
      if (fileMatch) {
        equipage = rest.slice(0, fileMatch.index).trim();
        const after = rest.slice(fileMatch.index + fileMatch[0].length);
        const depMatch = after.match(/\d{2}:\d{2}:\d{2}/);
        barreur = depMatch ? after.slice(0, depMatch.index).trim() : after.split(/\t/)[0].trim();
      } else {
        const firstTimeMatch = rest.match(/\d{1,2}:\d{2}\.\d{2}/);
        equipage = firstTimeMatch ? rest.slice(0, firstTimeMatch.index).trim() : rest.split(/\s{2,}/)[0];
      }

      rows.push({ event: currentEvent, type: currentType, pos, equipage, barreur, boat: currentBoat, cat: currentCat, finish, session: currentSession });
    }
  }
  return computeDtnFields(rows, regateName, distance);
};

const parsePdfText = (text, regateName, distance) => {
  const rows = [];
  let currentSession = null;

  const norm = text.replace(/[ \t]+/g, " ");

  const coursePositions = [];
  const re1 = /S[ée]rie:?\s*(\d+)\s+([A-Z0-9]+)\s+([12468][x\-+])\s*(PCM)?/gi;
  let mm;
  while ((mm = re1.exec(norm)) !== null) {
    coursePositions.push({ start: mm.index, end: mm.index + mm[0].length, name: mm[2] + " " + mm[3], type: mm[4] ? "Série PCM" : "Série" });
  }
  const re1b = /S[ée]rie:?\s*Course\s+\d+\s+([A-Z0-9]+?)([12468][x\-+])/gi;
  while ((mm = re1b.exec(norm)) !== null) {
    coursePositions.push({ start: mm.index, end: mm.index + mm[0].length, name: mm[1] + " " + mm[2], type: "Série" });
  }
  const re2 = /D([12])\s+([A-Z0-9]+)\s+([12468][x\-+])\s*Serie\s*(\d+)/gi;
  while ((mm = re2.exec(norm)) !== null) {
    coursePositions.push({ start: mm.index, end: mm.index + mm[0].length, name: mm[2] + " " + mm[3], type: `D${mm[1]}-Série${mm[4]}` });
  }
  const re3 = /S[ée]rie:?\s*(\d+)\s+([A-Z]{1,4})([12468][xX\-+])\s*(?=\(|Officiel|Non\s+officiel)/gi;
  while ((mm = re3.exec(norm)) !== null) {
    coursePositions.push({ start: mm.index, end: mm.index + mm[0].length, name: mm[2] + " " + mm[3].toLowerCase(), type: "Série" });
  }
  coursePositions.sort((a, b) => a.start - b.start);
  const filtered = [];
  coursePositions.forEach((cp) => {
    if (filtered.length && cp.start - filtered[filtered.length - 1].start < 30) return;
    filtered.push(cp);
  });

  if (!filtered.length) return [];

  for (let i = 0; i < filtered.length; i++) {
    const cur = filtered[i];
    const blockStart = cur.end;
    const blockEnd = i + 1 < filtered.length ? filtered[i + 1].start : norm.length;
    const block = norm.slice(blockStart, blockEnd);
    const boat = detectBoatCode(cur.name);
    const cat = detectCategoryCode(cur.name);

    const sessMatch = block.match(/(Vendredi|Samedi|Dimanche|Lundi)\s+(matin|ap[.\s]?midi|après[\s-]?midi)/i);
    const session = sessMatch ? detectSession(sessMatch[0]) : currentSession;
    if (session) currentSession = session;

    const headerStrip = (s) => s.replace(/Pos\.?\s+Equipage\s+File\s+(?:Nage\/Barreur\s+)?(?:Départ\s+)?(?:Temps\s+brut\s+)?(?:Ajustement\s+)?Finish(?:\s+Différence|\s+D\b)?/gi, " ")
                                 .replace(/Non\s+officiel|Officiel/gi, " ");

    const extractFromLine = (line) => {
      const m = line.match(/^(\d+)\s+(.+)/);
      if (!m) return null;
      const pos = m[1];
      let rest = m[2];
      const restNoTimestamp = rest.replace(/\d{1,2}:\d{2}:\d{2}(?:\.\d+)?/g, " ");
      const times = [...restNoTimestamp.matchAll(/(\d{1,2}:\d{2}\.\d+)/g)].map((x) => x[1]);
      if (!times.length) return null;
      const finishRaw = times[0];
      const finishIdx = restNoTimestamp.indexOf(finishRaw);
      let beforeTime = restNoTimestamp.slice(0, finishIdx).trim();
      const fileMatch = beforeTime.match(/^(.+?)\s+([A-Z]{0,2}\d{1,3})(?:\s+(.*))?$/);
      let equipage, barreur = "";
      if (fileMatch) {
        equipage = fileMatch[1].trim();
        barreur = (fileMatch[3] || "").trim();
      } else {
        equipage = beforeTime;
      }
      equipage = equipage.replace(/\(\d+\)\s*/g, " ").replace(/\s+/g, " ").trim();
      if (!equipage) return null;
      return { pos, equipage, barreur, finish: finishRaw };
    };

    const rawLines = headerStrip(block).split(/\r?\n/).map((l) => l.trim()).filter(Boolean);
    let lineResults = [];
    rawLines.forEach((line) => {
      const r = extractFromLine(line);
      if (r) lineResults.push(r);
    });

    const totalTimesInBlock = (headerStrip(block).replace(/\d{1,2}:\d{2}:\d{2}(?:\.\d+)?/g, " ").match(/\d{1,2}:\d{2}\.\d+/g) || []).length;

    if (lineResults.length < totalTimesInBlock) {
      lineResults = [];
      const cleanBlock = headerStrip(block);
      const timeRe = /(\d{1,2}:\d{2}\.\d+|Fini|DNS|DNF)/g;
      let tm;
      let lastEnd = 0;
      const segments = [];
      while ((tm = timeRe.exec(cleanBlock)) !== null) {
        segments.push({ text: cleanBlock.slice(lastEnd, tm.index), finish: tm[0] });
        lastEnd = tm.index + tm[0].length;
      }
      segments.forEach((seg) => {
        const finishRaw = seg.finish;
        if (!/^\d{1,2}:\d{2}\.\d+$/.test(finishRaw)) return;
        let txt = seg.text.trim();
        const fileMatch = txt.match(/([A-Z]{0,2}\d{1,3})\s*$/);
        let beforeFile = txt;
        if (fileMatch) beforeFile = txt.slice(0, fileMatch.index).trim();
        const posCandidates = [...beforeFile.matchAll(/(?:^|\s)(\d{1,3})\s+(?=[A-ZÀ-Ÿ(])/g)];
        let pos = "", equipage = beforeFile;
        if (posCandidates.length) {
          const last = posCandidates[posCandidates.length - 1];
          pos = last[1];
          equipage = beforeFile.slice(last.index + last[0].length).trim();
        } else {
          pos = String(rows.filter((r) => r.event === cur.name).length + lineResults.length + 1);
        }
        equipage = equipage.replace(/\(\d+\)\s*/g, " ").replace(/\s+/g, " ").trim();
        if (!equipage || equipage.length > 80) return;
        lineResults.push({ pos, equipage, barreur: "", finish: finishRaw });
      });
    }

    lineResults.forEach((r) => {
      const fs = parseTimeStr(r.finish);
      if (fs !== null && (fs < 30 || fs > 1500)) return;
      rows.push({ event: cur.name, type: cur.type, pos: r.pos, equipage: r.equipage, barreur: r.barreur, boat, cat, finish: r.finish, session: currentSession });
    });
  }
  return computeDtnFields(rows, regateName, distance);
};

// Extraction de texte brut (simple jointure des fragments pdf.js), utilisée pour
// les PDF CrewTimer "bruts" — différent du parseur par positions de colonnes
// (parsePdfClassement) qui cible nos propres exports "Classement".
const extractPdfPlainText = async (arrayBuffer) => {
  const pdf = await pdfjsLib.getDocument({ data: arrayBuffer.slice(0) }).promise;
  let fullText = "";
  for (let p = 1; p <= pdf.numPages; p++) {
    const page = await pdf.getPage(p);
    const content = await page.getTextContent();
    const pageText = content.items.map((it) => it.str).join(" ");
    fullText += pageText + "\n";
  }
  return fullText;
};

// Un CSV/texte est considéré "déjà traité" (notre format) s'il a déjà les
// colonnes % FFA-DTN / Top — sinon c'est un export CrewTimer brut à traiter.
const isAlreadyProcessed = (text) => {
  const firstLine = text.split(/\r?\n/)[0] || "";
  const lower = firstLine.toLowerCase();
  return lower.includes("ffa") || lower.includes("niveau dtn") || (lower.includes("équipage") && lower.includes("top"));
};

