  azimut: null, typeEau: "lac", courantMs: 0,
};
// le ramener aux conditions de référence (vent nul, eau 26°C).
// > 1 : conditions favorables → le chrono corrigé sera plus long
// < 1 : conditions difficiles → le chrono corrigé sera plus court
const meteoFactor = (ventFaceMs, tempEauC, boatType) => {
  const coefVent = COEF_VENT_BATEAU[boatType] !== undefined ? COEF_VENT_BATEAU[boatType] : COEF_VENT_DEFAUT;
  const deltaVitessePct = coefVent * ventFaceMs + COEF_TEMP_EAU * (tempEauC - TEMP_EAU_REF);
  return 1 + deltaVitessePct / 100;
};

const applyMeteoCorrection = (timeStr, boatType, ventFaceMs, tempEauC) => {
  const sec = parseTimeStr(timeStr);
  if (sec === null) return null;
  const factor = meteoFactor(ventFaceMs, tempEauC, boatType);
  return sec * factor; // secondes
};

