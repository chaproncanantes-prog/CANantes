const wrPaysNom = (code) => WR_PAYS[code.replace(/\d+$/, "")] || code;

const wrFmtTime = (s) => {
  if (s === null || s === undefined) return "";
  const m = Math.floor(s / 60), sec = s - m * 60;
  return `${String(m).padStart(2,"0")}:${sec.toFixed(2).padStart(5,"0")}`;
};

const parseWorldRowingPdf = async (arrayBuffer, fileLabel) => {
  const pdf = await pdfjsLib.getDocument({ data: arrayBuffer.slice(0) }).promise;
  const allLines = [];
  for (let p = 1; p <= pdf.numPages; p++) {
    const page = await pdf.getPage(p);
    const content = await page.getTextContent();
    const items = content.items.filter(it => it.str.trim());
    items.sort((a, b) => {
      const dy = Math.round(b.transform[5]) - Math.round(a.transform[5]);
      return dy !== 0 ? dy : a.transform[4] - b.transform[4];
    });
    const byY = new Map();
    for (const it of items) {
      const y = Math.round(it.transform[5] / 2) * 2;
      if (!byY.has(y)) byY.set(y, []);
      byY.get(y).push(it.str.trim());
    }
    for (const [, words] of [...byY.entries()].sort((a, b) => b[0] - a[0])) {
      allLines.push(words.join(" "));
    }
  }

  // Nom de la compétition : cherche une ligne avec le lieu connu
  const knownVenues = /Lucerne|Poznan|Seville|Amsterdam|Paris|Aiguebelette|Racice|Ottensheim|Vienna|Belgrade|Rotterdam|Henley/i;
  const titleLine = allLines.find(l => knownVenues.test(l));
  const competition = titleLine ? titleLine.replace(/\s+/g, " ").trim() : fileLabel;

  const RE_RACE    = /^(\d+)\s+(\d+:\d+)\s+((?:PR[13]\s+)?(?:Mix2x|[WM][1248][x+\-]+))\s+\(\d+\)\s+(Final\s*[AB]?)\s*$/;
  const RE_NATIONS = /^(?:[A-Z]{2,3}\d*\s*)+$/;
  const RE_CHRONOS = /\d+:\d+\.\d+/g;

  const races = [];
  for (let i = 0; i < allLines.length; i++) {
    const line = allLines[i].trim();
    const m = RE_RACE.exec(line);
    if (!m) continue;
    const nations = (i > 0 && RE_NATIONS.test(allLines[i-1].trim()))
      ? allLines[i-1].trim().split(/\s+/) : [];
    const chronos = i+1 < allLines.length
      ? (allLines[i+1].match(RE_CHRONOS) || []) : [];
    races.push({
      event: m[3].trim(), finale: m[4].trim(),
      bateaux: nations.slice(0, chronos.length).map((nat, idx) => ({
        rang: idx + 1, nation: nat, chrono: chronos[idx],
      })),
    });
  }

  if (races.length === 0) return { headers: [], rows: [] };

  const enriched = races.flatMap(race => {
    const info = WR_DTN_REF[race.event];
    const ref_s = info ? info.ref : null;
    return race.bateaux.map(b => {
      const parts = b.chrono.match(/(\d+):(\d+\.\d+)/);
      const s = parts ? parseInt(parts[1]) * 60 + parseFloat(parts[2]) : null;
      const pct = (ref_s && s) ? round2((ref_s / s) * 100) : null;
      return {
        ev: race.event, finale: race.finale,
        boat: info ? info.boat : race.event,
        cat: info ? info.cat : "X SA",
        ref_s, nat: b.nation, rang: b.rang, s, pct,
      };
    });
  });

  const validPcts = enriched.filter(r => r.pct && r.pct > 30 && r.pct < 130).map(r => r.pct);
  const topJournee = validPcts.length ? Math.max(...validPcts) : null;

  const headers = ["Régate","Journée","Épreuve","Type","Pos.","Équipage","Nage/Barreur",
    "Bateau","Catégorie DTN","Temps réalisé","Référence DTN","% FFA - DTN",
    "Top demi journée","Écart vs Top demi journée"];

  const rows = enriched.map(r => {
    const ecart = (topJournee && r.pct && r.pct > 30) ? round2(topJournee - r.pct) : null;
    return {
      "Régate":                    competition,
      "Journée":                   fileLabel,
      "Épreuve":                   `${r.ev} ${r.finale}`,
      "Type":                      r.finale,
      "Pos.":                      String(r.rang),
      "Équipage":                  wrPaysNom(r.nat),
      "Nage/Barreur":              r.nat,
      "Bateau":                    r.boat,
      "Catégorie DTN":             r.cat,
      "Temps réalisé":             wrFmtTime(r.s),
      "Référence DTN":             r.ref_s ? wrFmtTime(r.ref_s) : "",
      "% FFA - DTN":               r.pct ? `${r.pct.toFixed(2)}%` : "",
      "Top demi journée":          topJournee ? `${topJournee.toFixed(2)}%` : "",
      "Écart vs Top demi journée": ecart !== null ? `+${ecart.toFixed(2)}%` : "",
    };
  });

  return { headers, rows };
};

// Convertit les lignes calculées par le moteur DTN (objets bruts) au format
// {headers, rows-en-strings} attendu par ingestParsed.
// Calcule le temps moyen au 500m à partir d'un temps total et de la distance de
// course (ex. 2000m -> /4, 1500m -> /3, 1000m -> /2). Distance par défaut : 2000m
// si elle n'est pas connue pour cette ligne (cas des imports CSV/PDF déjà traités).
const split500 = (timeStr, distanceStr) => {
  const totalSec = parseTimeStr(timeStr);
  if (totalSec === null) return null;
  const distMatch = distanceStr ? String(distanceStr).match(/(\d+)/) : null;
  const dist = distMatch ? parseInt(distMatch[1], 10) : 2000;
  const segments = dist / 500;
  if (!segments) return null;
  return fmtTimeStr(totalSec / segments);
};

const rowsToParsedFormat = (rows) => {
  if (!rows.length) return { headers: [], rows: [] };
  const headers = Object.keys(rows[0]);
  const stringRows = rows.map((r) => {
    const o = {};
    headers.forEach((h) => { o[h] = String(r[h] ?? ""); });
    return o;
  });
  return { headers, rows: stringRows };
};

// Filtre à choix multiples (case à cocher) — sert pour Journée et Épreuve afin
// de pouvoir sélectionner une, plusieurs, ou toutes les valeurs.
function GroupedTypeFilter({ options, selected, onChange, groups }) {
  const [open, setOpen] = useState(false);
  const ref = useRef(null);

  useEffect(() => {
    const onClickOutside = (e) => {
      if (ref.current && !ref.current.contains(e.target)) setOpen(false);
    };
    document.addEventListener("mousedown", onClickOutside);
    return () => document.removeEventListener("mousedown", onClickOutside);
  }, []);

  // Groupe chaque option dans son groupe parent
  const grouped = groups.map(g => ({
    ...g,
    children: options.filter(o => o.startsWith(g.prefix))
  })).filter(g => g.children.length > 0);
  // Options sans groupe
  const ungrouped = options.filter(o => !groups.some(g => o.startsWith(g.prefix)));

  const toggleGroup = (children) => {
    const allSelected = children.every(c => selected.includes(c));
    if (allSelected) {
      onChange(selected.filter(s => !children.includes(s)));
    } else {
      const toAdd = children.filter(c => !selected.includes(c));
      onChange([...selected, ...toAdd]);
    }
  };

  const toggleOne = (o, checked) => {
    onChange(checked ? [...selected, o] : selected.filter(s => s !== o));
  };

  const buttonLabel = selected.length === 0
    ? "Toutes les progressions"
    : selected.length === 1
    ? selected[0]
    : `${selected.length} types sélectionnés`;

  return (
    <div ref={ref} style={{ position: "relative" }}>
      <button onClick={() => setOpen(v => !v)}>{buttonLabel} {open ? "▲" : "▼"}</button>
      {open && (
        <div style={{
          position: "absolute", zIndex: 20, top: "calc(100% + 4px)", left: 0, width: 260,
          maxHeight: 360, overflowY: "auto", background: "var(--bg-primary)",
          border: "1px solid var(--border-strong)", borderRadius: 10, padding: 10,
          boxShadow: "0 8px 24px rgba(0,0,0,0.12)",
        }}>
          <div style={{ display: "flex", gap: 8, marginBottom: 8, fontSize: 12 }}>
            <span style={{ cursor: "pointer", color: "var(--accent)", textDecoration: "underline" }} onClick={() => onChange(options)}>Tout cocher</span>
            <span style={{ cursor: "pointer", color: "var(--accent)", textDecoration: "underline" }} onClick={() => onChange([])}>Tout décocher</span>
          </div>
          {grouped.map(g => {
            const allSel = g.children.every(c => selected.includes(c));
            const someSel = g.children.some(c => selected.includes(c));
            return (
              <div key={g.label} style={{ marginBottom: 6 }}>
                {/* Case parent */}
                <label style={{ display: "flex", alignItems: "center", gap: 8, padding: "4px 2px", fontSize: 13, cursor: "pointer", fontWeight: 600 }}>
                  <input
                    type="checkbox"
                    checked={allSel}
                    ref={el => { if (el) el.indeterminate = someSel && !allSel; }}
                    onChange={() => toggleGroup(g.children)}
                  />
                  {g.label}
                  <span style={{ fontSize: 11, color: "var(--text-tertiary)", fontWeight: 400 }}>({g.children.length})</span>
                </label>
                {/* Cases enfants — affichées seulement si le groupe a plus d'1 option */}
                {g.children.length > 1 && g.children.map(o => (
                  <label key={o} style={{ display: "flex", alignItems: "center", gap: 8, padding: "3px 2px 3px 22px", fontSize: 12, cursor: "pointer", color: "var(--text-secondary)" }}>
                    <input
                      type="checkbox"
                      checked={selected.includes(o)}
                      onChange={e => toggleOne(o, e.target.checked)}
                    />
                    {o}
                  </label>
                ))}
              </div>
            );
          })}
          {ungrouped.map(o => (
            <label key={o} style={{ display: "flex", alignItems: "center", gap: 8, padding: "4px 2px", fontSize: 13, cursor: "pointer" }}>
              <input
                type="checkbox"
                checked={selected.includes(o)}
                onChange={e => toggleOne(o, e.target.checked)}
              />
              {o}
            </label>
          ))}
        </div>
      )}
    </div>
  );
}

